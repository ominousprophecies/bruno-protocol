meta {
  name: login_validation
  type: http
  seq: 2
}

post {
  url: {{base_url}}/post
  body: json
  auth: none
}

body:json {
  {
    "client_id": "{{client_secret}}",
    "grant_type": "client_credentials"
  }
}

assert {
  res.status: eq 200
  res.body.url: isString
}

script:post-response {
  if (res.status === 200 && res.body.url) {
    bru.setEnvVar("last_validated_url", res.body.url);
  }
}
